{
  "name": "el-form-benchmarks",
  "private": true,
  "type": "module",
  "description": "Dev-only benchmarks (TS path-typing perf + render-count). Not a workspace member; npm-managed in isolation so it never touches the pnpm lockfile or CI.",
  "scripts": {
    "bench:path": "node path-typing/run.mjs baseline elform rhf",
    "bench:render": "vitest run --environment jsdom render-count"
  },
  "devDependencies": {
    "@testing-library/react": "^14.1.2",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "el-form-react-hooks": "^3.12.0",
    "formik": "^2.4.6",
    "jsdom": "^24.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.0",
    "typescript": "^5.8.3",
    "vitest": "^2.0.0"
  }
}
